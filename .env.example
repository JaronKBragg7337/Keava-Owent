# Keava-Owent Environment Configuration
# Copy this file to .env and fill in your values

# Database / Persistent Store
DATABASE_URL=sqlite:///data/keava_owent.db

# Live Reference / External Sources (optional)
# LIVE_REFERENCE_API_KEY=your_key_here

# Transport / Email (for notifications or receipts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# System Parameters
LOG_LEVEL=INFO
MEMBRANE_MODE=balanced  # strict | balanced | permissive
WUE_COEFFICIENT=1.0
MAX_LEARNING_RATE=0.01

# Security / Secrets
SECRET_KEY=change-this-in-production
